{
    "layer": "top",
    "position": "top",
    "height": 42,
    "margin-top": 8,
    "margin-left": 12,
    "margin-right": 12,
    "spacing": 4,
    "exclusive": true,

    "modules-left": [
        "hyprland/workspaces",
        "hyprland/window"
    ],

    "modules-center": [
        "clock"
    ],

    "modules-right": [
        "custom/fps",
        "custom/music",
        "pulseaudio",
        "network",
        "cpu",
        "memory",
        "battery",
        "tray",
        "custom/power"
    ],

    "hyprland/workspaces": {
        "format": "{icon}",
        "on-click": "activate",
        "format-icons": {
            "1": "َ°² ",
            "2": "َ°²¢",
            "3": "َ°²¤",
            "4": "َ°²¦",
            "5": "َ°²¨",
            "6": "َ°²ھ",
            "7": "َ°²¬",
            "8": "َ°²®",
            "9": "َ°²°",
            "10": "َ°؟¬",
            "urgent": "َ°—–",
            "active": "َ°®¯",
            "default": "َ°ٹ "
        },
        "persistent-workspaces": {
            "*": 5
        },
        "sort-by-number": true
    },

    "hyprland/window": {
        "format": "  {}",
        "max-length": 40,
        "separate-outputs": true,
        "rewrite": {
            "(.*) â€” Mozilla Firefox": "َ°ˆ¹ $1",
            "(.*)Kitty": "َ°„› Terminal",
            "": "َ°‡„ Desktop"
        }
    },

    "clock": {
        "format": "َ°¥”  {:%H:%M}",
        "format-alt": "َ°ƒ­  {:%a, %d %b %Y}",
        "tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>",
        "interval": 1
    },

    "custom/fps": {
        "exec": "~/.config/waybar/scripts/fps.sh",
        "format": "َ°ٹ´  {}",
        "interval": 2,
        "tooltip": false,
        "on-click": "~/.config/hypr/scripts/fps-toggle.sh"
    },

    "custom/music": {
        "exec": "~/.config/waybar/scripts/music.sh",
        "format": "{}",
        "interval": 2,
        "escape": true,
        "on-click": "playerctl play-pause",
        "on-scroll-up": "playerctl next",
        "on-scroll-down": "playerctl previous",
        "max-length": 30
    },

    "pulseaudio": {
        "format": "{icon}  {volume}%",
        "format-muted": "َ°‌ں  Muted",
        "format-icons": {
            "headphone": "َ°‹‹",
            "hands-free": "َ°‹ژ",
            "headset": "َ°‹ژ",
            "phone": "َ°ڈ²",
            "portable": "َ°ڈ²",
            "car": "َ°„‹",
            "default": ["َ°•؟", "َ°–€", "َ°•¾"]
        },
        "on-click": "pavucontrol",
        "on-scroll-up": "wpctl set-volume @DEFAULT_AUDIO_SINK@ 2%+",
        "on-scroll-down": "wpctl set-volume @DEFAULT_AUDIO_SINK@ 2%-",
        "scroll-step": 2,
        "tooltip-format": "{desc} â€” {volume}%"
    },

    "network": {
        "format-wifi": "َ°¤¨  {essid}",
        "format-ethernet": "َ°ˆ€  {ifname}",
        "format-disconnected": "َ°¤­  Offline",
        "format-linked": "َ°ˆ€  {ifname} (No IP)",
        "tooltip-format-wifi": "َ°¤¨ {essid} ({signalStrength}%)\nَ°©ں {ipaddr}/{cidr}\nâ¬‡ {bandwidthDownBits}  â¬† {bandwidthUpBits}",
        "tooltip-format-ethernet": "َ°ˆ€ {ifname}\nَ°©ں {ipaddr}/{cidr}",
        "on-click": "nm-connection-editor",
        "interval": 5
    },

    "cpu": {
        "format": "َ°»   {usage}%",
        "tooltip-format": "CPU: {usage}%\nLoad: {load}",
        "interval": 2,
        "on-click": "kitty -e btop"
    },

    "memory": {
        "format": "َ°چ›  {percentage}%",
        "tooltip-format": "RAM: {used:0.1f}G / {total:0.1f}G\nSwap: {swapUsed:0.1f}G / {swapTotal:0.1f}G",
        "interval": 3,
        "on-click": "kitty -e btop"
    },

    "battery": {
        "states": {
            "warning": 30,
            "critical": 15
        },
        "format": "{icon}  {capacity}%",
        "format-charging": "َ°‚„  {capacity}%",
        "format-plugged": "َ°‚„  {capacity}%",
        "format-icons": ["َ°‚ژ", "َ°پ؛", "َ°پ»", "َ°پ¼", "َ°پ½", "َ°پ¾", "َ°پ؟", "َ°‚€", "َ°‚پ", "َ°‚‚", "َ°پ¹"],
        "tooltip-format": "{timeTo} â€” {capacity}%"
    },

    "tray": {
        "icon-size": 16,
        "spacing": 8
    },

    "custom/power": {
        "format": "َ°گ¥",
        "on-click": "~/.config/waybar/scripts/power-menu.sh",
        "tooltip": false
    }
}
